// SimulationCore.cs - 这是完全独立的计算模块
using System.Threading;
using System.Diagnostics;
int CellMaxNum = 100;//每个环境格能容纳细胞的总数的最大值
int CellTotalMaxNum = 2000000;
int GeneNum = 1000;
int WorldSeed = 12345;
int EnvirSize = 1000;//环境格的总大小为EnvirSize*EnvirSize
int PixelPerEnvir = 10;//每个环境格对应的像素大小,决定了缩放大小
LinkedList<Cell>[] CellList = new LinkedList<Cell>[CellTotalMaxNum+5];
List<int>[] FuncList = new List<int>[GeneNum+5];

/*功能编号
1--繁殖
1--基础繁殖 （10%几率繁殖、在自身及周围八格中随机选择一格能繁殖的繁殖）
2--基础温度耐受 （25-30）
3--基础光照需求 （0-100）
4--基础寿命 （每回合5%几率死亡）
5--拥挤（周围八连通超过6个个体时，死亡）
*/

Random predictableRandom = new Random(WorldSeed);
//自动补全回答：md中，“对任意的”数学符号怎么写？在Markdown中，您可以使用LaTeX语法来表示数学符号。对于“对任意的”，通常使用符号“∀”。在Markdown中，您可以这样写：
